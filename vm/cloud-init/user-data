#cloud-config
# AI Desktop Agent VM — cloud-init user-data
# 初回起動時にKDE Plasmaデスクトップ環境をセットアップする

hostname: desktop-agent
manage_etc_hosts: true

# インストールパッケージ
# - kde-plasma-desktop: KDE Plasma 最小デスクトップ
# - sddm: KDEネイティブのディスプレイマネージャ（自動ログイン用）
# - konsole, firefox: AIが操作するアプリケーション
# - xdotool, wmctrl: ウィンドウ操作ユーティリティ
packages:
  - kde-plasma-desktop
  - sddm
  - konsole
  - firefox
  - dolphin
  - xdotool
  - wmctrl
  - libgl1-mesa-dri

# エージェント用ユーザー
users:
  - name: agent
    gecos: "AI Desktop Agent"
    sudo: "ALL=(ALL) NOPASSWD:ALL"
    lock_passwd: false
    shell: /bin/bash

# SDDM 設定
# - DisplayServer=x11: QEMU仮想GPUではWaylandがクラッシュするためX11固定
# - Autologin: agentユーザーでPlasmaに自動ログイン
write_files:
  - path: /etc/sddm.conf.d/autologin.conf
    content: |
      [Autologin]
      User=agent
      Session=plasma
      Relogin=false

      [General]
      DisplayServer=x11
      HaltCommand=
      RebootCommand=
    permissions: "0644"
  
  # 念のためsddm.confにも書いておく（sddm.conf.dが読み込まれない環境対策）
  - path: /etc/sddm.conf
    content: |
      [Autologin]
      User=agent
      Session=plasma
      Relogin=false

      [General]
      DisplayServer=x11
    permissions: "0644"

  # agentの.profile: tty1かつX未起動ならKDEを自動起動
  - path: /home/agent/.profile
    content: |
      # ~/.profile: getty自動ログイン時、KDE Plasmaを自動起動
      if [ -z "$DISPLAY" ] && [ "$(tty)" = "/dev/tty1" ]; then
          exec startplasma-x11
      fi
    owner: "agent:agent"
    permissions: "0644"

# 起動時コマンド
runcmd:
  - echo "agent:agent" | chpasswd
  # getty自動ログイン設定（write_filesより後に実行するためruncmdで作成）
  - mkdir -p /etc/systemd/system/getty@tty1.service.d
  - |
    cat > /etc/systemd/system/getty@tty1.service.d/autologin.conf << 'EOF'
    [Service]
    ExecStart=
    ExecStart=-/sbin/agetty --autologin agent --noclear %I $TERM
    EOF
  - systemctl enable sddm
  - systemctl set-default graphical.target

final_message: "VM setup complete. KDE Plasma desktop is ready at VNC port 5900."
