#cloud-config
# AI Desktop Agent VM — cloud-init user-data
# getty自動ログイン → .profileからKDE Plasmaを起動（SDDM不要）

hostname: desktop-agent
manage_etc_hosts: true

# インストールパッケージ
# - kde-plasma-desktop: KDE Plasma 最小デスクトップ
# - konsole, firefox: AIが操作するアプリケーション
# - xdotool, wmctrl: ウィンドウ操作ユーティリティ
# - xauth: startplasma-x11に必要
packages:
  - kde-plasma-desktop
  - konsole
  - firefox
  - dolphin
  - xdotool
  - wmctrl
  - xauth

# エージェント用ユーザー
users:
  - name: agent
    gecos: "AI Desktop Agent"
    sudo: "ALL=(ALL) NOPASSWD:ALL"
    lock_passwd: false
    shell: /bin/bash

# 設定ファイル
write_files:
  # agentの.profile: tty1ならKDEを自動起動
  - path: /home/agent/.profile
    content: |
      # ~/.profile: コンソールログイン時にKDE Plasmaを自動起動
      if [ -z "$DISPLAY" ] && [ "$(tty)" = "/dev/tty1" ]; then
          exec startplasma-x11
      fi
    owner: "agent:agent"
    permissions: "0644"

# 起動時コマンド
runcmd:
  # agentユーザーのパスワード設定
  - echo "agent:agent" | chpasswd

  # getty@tty1 で agent を自動ログイン
  - mkdir -p /etc/systemd/system/getty@tty1.service.d
  - |
    cat > /etc/systemd/system/getty@tty1.service.d/autologin.conf << 'EOF'
    [Service]
    ExecStart=
    ExecStart=-/sbin/agetty --autologin agent --noclear %I $TERM
    EOF

  # システム起動時の自動ログイン用にautologin@tty1を有効化（gettyの代わり）
  - systemctl daemon-reload
  - systemctl enable getty@tty1

# cloud-init完了後にVM自身が綺麗にpoweroff → QEMUが-no-rebootで終了
power_state:
  mode: poweroff
  timeout: 30
  condition: true

final_message: "VM setup complete. KDE Plasma desktop will start automatically on next boot via getty autologin."
