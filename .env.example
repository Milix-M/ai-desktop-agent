# AI Desktop Agent — 環境変数設定
# .env.example を .env にコピーして API キーを設定してください

# ── LLM プロバイダ ───────────────────────────────────
# 以下のいずれか 1 つを設定

# OpenAI（推奨）
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here

# OpenRouter（マルチプロバイダ、安価）
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Anthropic
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── モデル ───────────────────────────────────────────
# 省略可。デフォルトはプロバイダごとに設定済み
# LLM_MODEL=gpt-4o

# ── VM 設定 ──────────────────────────────────────────
# KVM が使える場合は true（デフォルト: false = TCG ソフトウェアエミュレーション）
USE_KVM=false
